    "GET_BUTTON_L_GPIO_LOW": "BoseManufacturingTool.exe  send \"Debug.GPIO.Get 9\" --expect \"Debug\\.GPIO\\.Status GPIONum=9 Level=Low Direction=Input\" --print_response --serial_number \"{}\"",
