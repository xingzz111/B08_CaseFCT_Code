{
    "READ_PCBA_SN": "BoseManufacturingTool.exe send \"Manufacturing.SerialNumber.Get 1\" --expect \".\" --print_response --serial_number \"{}\"",
    "WRITE_HW_VERSION": "BoseManufacturingTool.exe send \"Manufacturing.HardwareRevision.SetGet C0\" --expect \"Manufacturing\\.HardwareRevision\\.Status HWRevision=c0\"  --print_response --serial_number \"{}\"",
    "WRITE_HW_VERSION_C1": "BoseManufacturingTool.exe send \"Manufacturing.HardwareRevision.SetGet C1\" --expect \"Manufacturing\\.HardwareRevision\\.Status HWRevision=c1\"  --print_response --serial_number \"{}\"",
