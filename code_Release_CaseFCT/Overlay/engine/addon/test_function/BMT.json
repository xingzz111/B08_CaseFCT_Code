    "WLSS_RX_ADC_IOUT_1": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.Get 0x30, 1, 1, 0x28\" --expect \".\" --print_response --serial_number \"{}\"",
    "WLSS_RX_ADC_IOUT_2": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.Get 0x30, 1, 1, 0x29\" --expect \".\" --print_response --serial_number \"{}\"",
    "WLSS_RX_ADC_VOUT_1": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.Get 0x30, 1, 1, 0x2a\" --expect \".\" --print_response --serial_number \"{}\"",
