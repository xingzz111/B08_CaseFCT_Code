    "GET_FW_VISION": "BoseManufacturingTool.exe  send \"ProductInfo.FirmwareVersion.Get\" --expect \".\" --print_response --serial_number \"{}\"",
    "CHARGER_I2C_TEST": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.Get 0x6a, 1, 1, 0x38\" --expect \"Manufacturing.I2CCheck.Status Status=0 StatusQualifier=34\" --print_response --serial_number \"{}\"",
    "WRITE_TEST_STATION_FLAG": "BoseManufacturingTool.exe  send \"Manufacturing.TestStation.SetGet 1, 1\" --expect \".\" --print_response --serial_number \"{}\"",
