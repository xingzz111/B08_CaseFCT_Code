{
    "GET_VERSION": "BoseManufacturingTool.exe -h --print_response",
    "READ_PCBA_SN": "BoseManufacturingTool.exe send \"Manufacturing.SerialNumber.Get 1\" --expect \".\" --print_response --serial_number \"{}\"",
    "WRITE_HW_VERSION": "BoseManufacturingTool.exe send \"Manufacturing.HardwareRevision.SetGet C1\" --expect \"Manufacturing\\.HardwareRevision\\.Status HWRevision=C1\"  --print_response --serial_number \"{}\"",
    "CC_TX_RX_TEST": "BoseManufacturingTool.exe  send \"CaseDebug.PowerLineCommsLoopback.Start 0\" --expect \".\" --print_response --serial_number \"{}\"",
    "GET_HW_REVISION": "BoseManufacturingTool.exe  send \"Manufacturing.HardwareRevision.Get\" --expect \".\" --print_response --serial_number \"{}\"",
    "GET_FW_VISION": "BoseManufacturingTool.exe  send \"ProductInfo.FirmwareVersion.Get\" --expect \".\" --print_response --serial_number \"{}\"",
    "CHARGER_INT_STATUS": "BoseManufacturingTool.exe  send \"Debug.GPIO.Get 2\" --expect \".\" --print_response --serial_number \"{}\"",
    "WIRELESS_INT_STATUS": "BoseManufacturingTool.exe  send \"Debug.GPIO.Get 31\" --expect \".\" --print_response --serial_number \"{}\"",
    "CHARGER_I2C_TEST": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.Get 0x3C, 1, 1, 0x01\" --expect \".\" --print_response --serial_number \"{}\"",
    "OUTPUT_5V": "BoseManufacturingTool.exe  send \"CaseDebug.ChargerInterconnectVoltControl.SetGet 1\" --expect \".\" --print_response --serial_number \"{}\"",
    "HALL_KEY_GPIO": "BoseManufacturingTool.exe  send \"Debug.GPIO.Get 23\" --expect \".\" --print_response --serial_number \"{}\"",
    "DISABLE_CASE_POGO_OUTPUT": "BoseManufacturingTool.exe  send \"CaseDebug.ChargerInterconnectBudControl.Start 3\" --expect \".\" --print_response --serial_number \"{}\"",
    "SET_LED_CASE_WHITE_255": "BoseManufacturingTool.exe  send \"Manufacturing.LedAttribute.SetGet 1,1,255\" --expect \".\" --print_response --serial_number \"{}\"",
    "SET_LED_CASE_WHITE_ON": "BoseManufacturingTool.exe  send \"Debug.LEDs.SetGet 13, 31\" --expect \".\" --print_response --serial_number \"{}\"",
    "SET_LED_CASE_AMBER_255": "BoseManufacturingTool.exe  send \"Manufacturing.LedAttribute.SetGet 2,1,255\" --expect \".\" --print_response --serial_number \"{}\"",
    "SET_LED_CASE_AMBER_ON": "BoseManufacturingTool.exe  send \"Debug.LEDs.SetGet 13, 32\" --expect \".\" --print_response --serial_number \"{}\"",
    "SET_LED_CASE_BLUE_255": "BoseManufacturingTool.exe  send \"Manufacturing.LedAttribute.SetGet 3,1,255\" --expect \".\" --print_response --serial_number \"{}\"",
    "SET_LED_CASE_BLUE_ON": "BoseManufacturingTool.exe  send \"Debug.LEDs.SetGet 13, 33\" --expect \".\" --print_response --serial_number \"{}\"",
    "CASE_RESET": "BoseManufacturingTool.exe  send \"Control.Reset.Start\" --expect \".\" --print_response --serial_number \"{}\"",
    "GET_BUTTON_L_GPIO_LOW": "BoseManufacturingTool.exe  send \"Debug.GPIO.Get 45\" --expect \"Debug\\.GPIO\\.Status GPIONum=45 Level=Low Direction=Input\" --print_response --serial_number \"{}\"",
    "GET_BUTTON_L_GPIO_HIGH": "BoseManufacturingTool.exe  send \"Debug.GPIO.Get 45\" --expect \"Debug\\.GPIO\\.Status GPIONum=45 Level=High Direction=Input\" --print_response --serial_number \"{}\"",
    "42_1V8_MOS_EN1_LOW": "BoseManufacturingTool.exe  send \"Debug.GPIO.SetGet 17, 0, 2, 3\" --expect \".\" --print_response --serial_number \"{}\"",
    "42_1V8_MOS_EN1_HIGH": "BoseManufacturingTool.exe  send \"Debug.GPIO.SetGet 17, 1, 2, 3\" --expect \".\" --print_response --serial_number \"{}\"",
    "42_1V8_MOS_EN2_LOW": "BoseManufacturingTool.exe  send \"Debug.GPIO.SetGet 18, 0, 2, 3\" --expect \".\" --print_response --serial_number \"{}\"",
    "42_1V8_MOS_EN2_HIGH": "BoseManufacturingTool.exe  send \"Debug.GPIO.SetGet 18, 1, 2, 3\" --expect \".\" --print_response --serial_number \"{}\"",
    "BUD_RESET_GPIO_HIGH": "BoseManufacturingTool.exe  send \"Debug.GPIO.SetGet 5, 1, 2, 3\" --expect \".\" --print_response --serial_number \"{}\"",
    "BUD_RESET_GPIO_LOW": "BoseManufacturingTool.exe  send \"Debug.GPIO.SetGet 5, 0, 2, 3\" --expect \".\" --print_response --serial_number \"{}\"",
    "NTC_JEITA_IO_TO_HIGH": "BoseManufacturingTool.exe  send \"Debug.GPIO.SetGet 6, 1, 2, 3\" --expect \".\" --print_response --serial_number \"{}\"",
    "SET_BATTERY_TEMPERATURE": "BoseManufacturingTool.exe  send \"Manufacturing.ChargerEnabled.SetGet 1\" --expect \".\" --return_all --print_response --serial_number \"{}\"",
    "CHARGE_DISABLE": "BoseManufacturingTool.exe  send \"Manufacturing.ChargerEnabled.SetGet 0\" --expect \".\" --print_response --serial_number \"{}\"",
    "WLSS_RX_CHIP_ID": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.Get 0x30, 2, 2, 0x10\" --expect \".\" --print_response --serial_number \"{}\"",
    "WLSS_RX_STATUS": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.Get 0x30, 1, 1, 0x16\" --expect \".\" --print_response --serial_number \"{}\"",
    "WRITE_TEST_STATION_FLAG": "BoseManufacturingTool.exe  send \"Manufacturing.TestStation.SetGet 0, 1\" --expect \".\" --print_response --serial_number \"{}\"",
    "WIRELESS_CHARGER_I2C_TEST": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.Get 0x30, 1, 1, 0x10\" --expect \".\" --print_response --serial_number \"{}\"",
    "POGO_DISABLE": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.SetGet 0x3C, 2, 1, 0x02, 0x10\" --expect \".\" --print_response --serial_number \"{}\"",
    "POGO_ENABLE": "BoseManufacturingTool.exe  send \"Manufacturing.I2CCheck.SetGet 0x3C, 2, 1, 0x02, 0x30\" --expect \".\" --print_response --serial_number \"{}\"",
    "READ_TEST_STATION_FLAG": "BoseManufacturingTool.exe  send \"Manufacturing.TestStation.Get\" --expect \"Manufacturing.TestStation\\.Status\" --print_response --serial_number \"{}\"",
    "POWER_OFF": "BoseManufacturingTool.exe  send \"Control.Power.Start 0\" --expect \".\" --print_response --serial_number \"{}\""
}
